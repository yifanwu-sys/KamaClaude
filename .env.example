# KamaClaude 环境配置模板
# 用法：cp .env.example .env，然后按需修改

# ── Core Daemon ───────────────────────────────────────────────
KAMA_HOST=127.0.0.1
KAMA_PORT=7437

# ── Logging ───────────────────────────────────────────────────
KAMA_LOG_LEVEL=INFO
# 留空则仅输出 stderr，不写文件
KAMA_LOG_FILE=~/.kama/logs/core.log
# text（人工可读键值对）或 json（结构化，适合日志聚合）
KAMA_LOG_FORMAT=text

# ── Config File ───────────────────────────────────────────────
# KAMA_CONFIG=~/.kama/config.toml

# ── LLM（S1 阶段启用）────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# KAMA_LLM_DEFAULT_MODEL=claude-sonnet-4-6
# KAMA_MAX_STEPS=20
